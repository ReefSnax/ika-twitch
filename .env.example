# Twitch bot account credentials
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNEL=

# Twitch API (for stream status checks)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Bot user OAuth for moderator actions (e.g. /shoutout via API)
# Generate at https://twitchtokengenerator.com/ with moderator:manage:shoutouts scope
TWITCH_USER_OAUTH=

# EventSub relay (for follow events)
# Generate a random string: openssl rand -hex 32
EVENTSUB_SECRET=
EVENTSUB_PORT=

# Anthropic
ANTHROPIC_API_KEY=

# Debug mode (set to true for verbose tmi.js logs)
DEBUG=
